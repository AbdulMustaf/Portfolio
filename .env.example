GEMINI_API_KEY=
# Any valid Gemini model ID. Defaults to gemini-2.0-flash-lite when unset.
# Other options: gemini-2.0-flash, gemini-1.5-flash, gemini-2.5-flash
GEMINI_MODEL=gemini-2.0-flash-lite

# Vercel KV / Upstash Redis REST credentials for a persistent viewer count.
# Get these from: Vercel Dashboard → Storage → Create KV Database → .env.local tab
# Without these, /api/viewer-count falls back to a per-instance in-memory counter.
KV_REST_API_URL=
KV_REST_API_TOKEN=
